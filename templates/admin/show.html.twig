{% extends 'base.html.twig' %}

{% block title %}{{ 'admin.title' | trans }}{% endblock %}

{% block header %}
    <header class="layout__header header cols cols--always cols--center cols--gap-small" role="banner">
        <div class="col--extend">
            <a class="header__title" href="{{ path('admin') }}">
                {{ appName }}
            </a>
        </div>

        <div class="cols cols--gap-small">
            <button
                class="header__button button--small"
                data-controller="modal-opener"
                data-action="modal-opener#fetch"
                data-modal-opener-selector-value="{{ path('edit preferences') }}"
            >
                {{ icon('gear') }}
                {{ 'layout.header.preferences' | trans }}
            </button>

            <form action="{{ path('logout') }}" method="post" data-turbo="false">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">

                <button class="header__button" type="submit">
                    {{ 'layout.logout' | trans }}
                </button>
            </form>
        </div>
    </header>
{% endblock %}

{% block body %}
    <div class="wrapper wrapper--center flow flow--larger">
        <h1>
            {{ 'admin.title' | trans }}
        </h1>

        <div class="flow flow--large">
            <h2>
                {% if includeAllPolls %}
                    {{ 'admin.polls.title' | trans }}
                {% else %}
                    {{ 'admin.polls.my_title' | trans }}
                {% endif %}
            </h2>

            <form class="cols cols--gap-smaller">
                <input type="text" name="q" value="{{ search }}">

                <button class="button--primary">
                    {{ 'admin.polls.search' | trans }}
                </button>
            </form>

            {% if pollsPagination.count > 0 %}
                <div class="flow">
                    {{ include('_pagination.html.twig', { pagination: pollsPagination }) }}

                    <ul class="list--nostyle flow">
                        {% for poll in pollsPagination.items %}
                            <li class="panel panel--primary panel--rounded flow flow--small">
                                <h3>{{ poll.title }}</h3>

                                <ul class="list--nostyle flow flow--small">
                                    <li class="cols cols--gap-smaller">
                                        <span class="col--size2">
                                            {{ 'admin.polls.author' | trans }}
                                        </span>

                                        <strong>
                                            {{ poll.authorName }}
                                            {% if poll.authorEmail %}
                                                ({{ poll.authorEmail }})
                                            {% endif %}
                                        </strong>
                                    </li>

                                    <li class="cols cols--gap-smaller">
                                        <span class="col--size2">
                                            {{ 'admin.polls.created_at' | trans }}
                                        </span>

                                        <strong>
                                            <time datetime="{{ poll.createdAt | dateIso }}">
                                                {{ poll.createdAt | dateTrans }}
                                            </time>
                                        </strong>
                                    </li>

                                    <li class="cols cols--gap-smaller">
                                        <span class="col--size2">
                                            {{ 'admin.polls.public_link' | trans }}
                                        </span>

                                        {% if poll.isCompleted %}
                                            <a href="{{ url('poll', { slug: poll.slug }) }}">
                                                {{ url('poll', { slug: poll.slug }) }}
                                            </a>
                                        {% else %}
                                            <em>
                                                {{ 'admin.polls.not_completed' | trans }}
                                            </em>
                                        {% endif %}
                                    </li>

                                    <li class="cols cols--gap-smaller">
                                        <span class="col--size2">
                                            {{ 'admin.polls.admin_link' | trans }}
                                        </span>

                                        <a href="{{ url('poll admin', { id: poll.id, token: poll.adminToken }) }}">
                                            {{ url('poll admin', { id: poll.id, token: poll.adminToken }) }}
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        {% endfor %}
                    </ul>

                    {{ include('_pagination.html.twig', { pagination: pollsPagination }) }}
                </div>
            {% else %}
                <p class="panel panel--grey panel--rounded">
                    {{ 'admin.polls.none' | trans }}
                </p>
            {% endif %}
        </div>
    </div>
{% endblock %}
