<!DOCTYPE html>
<html lang="{{ app.locale|locale_to_bcp47 }}" data-controller="color-scheme" data-color-scheme="auto">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        {% set block_title %}{% block title %}{% endblock %}{% endset %}
        {% set block_meta_description %}{% block meta_description %}{% endblock %}{% endset %}
        {% set block_social_title %}{% block social_title %}{% endblock %}{% endset %}
        {% set block_social_description %}{% block social_description %}{% endblock %}{% endset %}
        {% set block_canonical_url %}{% block canonical_url %}{% endblock %}{% endset %}
        {% set block_social_image %}{% block social_image %}{% endblock %}{% endset %}
        {% set block_social_image_alt %}{% block social_image_alt %}{% endblock %}{% endset %}
        {% set block_social_image_width %}{% block social_image_width %}{% endblock %}{% endset %}
        {% set block_social_image_height %}{% block social_image_height %}{% endblock %}{% endset %}
        {% set block_social_image_type %}{% block social_image_type %}{% endblock %}{% endset %}
        {% if block_title is not empty %}
            {% set page_title = "#{block_title|striptags|trim} – #{appName}" %}
        {% else %}
            {% set page_title = 'base.default_title' | trans({ appName: appName}) %}
        {% endif %}
        {% set meta_description = block_meta_description|striptags|replace({'\r': ' ', '\n': ' '})|trim %}
        {% if meta_description is empty %}
            {% set meta_description = page_title %}
        {% endif %}
        {% set canonical_url = block_canonical_url|trim %}
        {% if canonical_url is empty %}
            {% set canonical_url = app.request.uri %}
        {% endif %}
        {% set social_title = block_social_title|striptags|trim %}
        {% if social_title is empty %}
            {% set social_title = page_title %}
        {% endif %}
        {% set social_description = block_social_description|striptags|replace({'\r': ' ', '\n': ' '})|trim %}
        {% if social_description is empty %}
            {% set social_description = meta_description %}
        {% endif %}
        {% set social_image = block_social_image|trim %}
        {% if social_image is empty %}
            {% set social_image = absolute_url(asset('screenshot.webp')) %}
        {% endif %}
        {% set social_image_alt = block_social_image_alt|striptags|trim %}
        {% if social_image_alt is empty %}
            {% set social_image_alt = appName %}
        {% endif %}
        {% set social_image_width = block_social_image_width|trim %}
        {% if social_image_width is empty %}
            {% set social_image_width = '1280' %}
        {% endif %}
        {% set social_image_height = block_social_image_height|trim %}
        {% if social_image_height is empty %}
            {% set social_image_height = '800' %}
        {% endif %}
        {% set social_image_type = block_social_image_type|trim %}
        {% if social_image_type is empty %}
            {% set social_image_type = 'image/webp' %}
        {% endif %}

        <title>{{ page_title }}</title>
        <meta name="description" content="{{ meta_description }}">
        <link rel="canonical" href="{{ canonical_url }}">
        <meta property="og:locale" content="{{ app.locale|locale_to_bcp47 }}">
        <meta property="og:site_name" content="{{ appName }}">
        <meta property="og:type" content="{% block og_type %}website{% endblock %}">
        <meta property="og:title" content="{{ social_title }}">
        <meta property="og:description" content="{{ social_description }}">
        <meta property="og:url" content="{{ canonical_url }}">
        <meta property="og:image" content="{{ social_image }}">
        <meta property="og:image:secure_url" content="{{ social_image }}">
        <meta property="og:image:type" content="{{ social_image_type }}">
        <meta property="og:image:width" content="{{ social_image_width }}">
        <meta property="og:image:height" content="{{ social_image_height }}">
        <meta property="og:image:alt" content="{{ social_image_alt }}">
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="{{ social_title }}">
        <meta name="twitter:description" content="{{ social_description }}">
        <meta name="twitter:image" content="{{ social_image }}">
        <meta name="twitter:image:alt" content="{{ social_image_alt }}">

        {% set primary_font = asset_match('assets/lexend-latin-*.woff2') %}
        {% if primary_font %}
            <link rel="preload" href="{{ primary_font }}" as="font" type="font/woff2" crossorigin>
        {% endif %}

        {% block stylesheets %}
            <link rel="stylesheet" href="{{ esbuild_asset('styles/application.css') }}" data-turbo-track="reload">
        {% endblock %}

        {% if asset_exists('custom.css') %}
            <link rel="stylesheet" href="{{ asset('custom.css') }}">
        {% endif %}

        {% block javascripts %}
            <script src="{{ esbuild_asset('js/application.js') }}" defer data-turbo-track="reload"></script>
        {% endblock %}

        {% if asset_exists('custom.js') %}
            <script src="{{ asset('custom.js') }}" defer data-turbo-track="reload"></script>
        {% endif %}

        {% block robots_head_tags %}
            <meta name="robots" content="noindex, nofollow">
        {% endblock %}

        {% block additional_head_tags %}
        {% endblock %}
    </head>

    <body>
        <div class="layout" id="layout">
            {% block header %}
                <header class="layout__header header no-print" role="banner" data-controller="nav-toggle">
                    <div class="header__brand">
                        <a class="header__title" href="{{ path('home') }}">
                            {{ appName }}
                        </a>

                        <button
                            class="header__hamburger"
                            type="button"
                            data-action="nav-toggle#toggle"
                            data-nav-toggle-target="button"
                            aria-expanded="false"
                            aria-label="Menu"
                        >
                            <span></span>
                            <span></span>
                            <span></span>
                        </button>
                    </div>

                    <nav class="header__nav" data-nav-toggle-target="nav">
                        <div class="header__links">
                            <a class="header__link" href="{{ path('public polls') }}">
                                {{ 'layout.header.public_polls' | trans }}
                            </a>

                            <a class="header__link" href="{{ path('my') }}">
                                {{ 'layout.header.my' | trans }}
                            </a>

                            {% if is_granted('ROLE_ADMIN') %}
                                <a class="header__link" href="{{ path('admin') }}">
                                    {{ 'admin.title' | trans }}
                                </a>
                            {% endif %}
                        </div>

                        <div class="header__actions">
                            <button
                                class="header__button button--small"
                                data-controller="modal-opener"
                                data-action="modal-opener#fetch"
                                data-modal-opener-selector-value="{{ path('edit preferences') }}"
                            >
                                {{ icon('gear') }}
                                {{ 'layout.header.preferences' | trans }}
                            </button>

                            {% if app.user %}
                                <form action="{{ path('logout') }}" method="post" data-turbo="false">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('logout') }}">

                                    <button class="header__button button--small" type="submit">
                                        {{ 'layout.logout' | trans }}
                                    </button>
                                </form>
                            {% else %}
                                <a class="button header__button button--small" href="{{ path('login', {'returnto': app.request.pathinfo}) }}">
                                    {{ 'layout.login' | trans }}
                                </a>
                            {% endif %}
                        </div>
                    </nav>
                </header>
            {% endblock %}

            <main class="layout__body {% block main_class %}{% endblock %}" id="content" tabindex="-1">
                {% block body %}
                {% endblock %}
            </main>
        </div>

        {{ include('_modal_dialog.html.twig') }}
    </body>
</html>
