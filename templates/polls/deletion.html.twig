{% extends 'modal.html.twig' %}

{% block title %}{{ 'polls.deletion.title' | trans }}{% endblock %}

{% block body %}
    {{ form_start(form, {
        action: path('delete poll', { id: poll.id, token: poll.adminToken }),
    }) }}
        <p>
            {{ 'polls.deletion.information' | trans({ title: poll.title | escape }) | raw }}
        </p>

        {{ form_errors(form) }}

        {{ form_row(form.submit) }}
    {{ form_end(form) }}
{% endblock %}
