{% extends 'base.html.twig' %}

{% block robots_head_tags %}
    <meta name="robots" content="index, follow">
{% endblock %}

{% block meta_description %}{{ 'home.intro' | trans }}{% endblock %}

{% block social_image %}{{ absolute_url(asset('screenshot.webp')) }}{% endblock %}

{% block social_image_alt %}{{ 'home.title' | trans }}{% endblock %}

{% block main_class %}layout__body--centered{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ esbuild_asset('home/application.css') }}" data-turbo-track="reload">
{% endblock %}

{% block header %}
    {{ parent() }}

    {% if is_granted('ROLE_USER') %}
        <div class="wrapper wrapper--center home-welcome">
            <p class="text--primary text--bold">
                {{ 'home.welcome' | trans({ name: app.user.displayName }) }}
            </p>
        </div>
    {% endif %}
{% endblock %}

{% block body %}
    <div class="flow flow--larger" style="max-width: 900px; width: 100%; text-align: center;">

        {% for message in app.flashes('success') %}
            {% if message == 'poll.deleted' %}
                {{ include('notifications/_success.html.twig', { message: 'home.show.poll.deleted' | trans }) }}
            {% endif %}
        {% endfor %}

        <div class="cols cols--gap-large" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px;">
            <div class="col--extend flow flow--large" style="flex: 1;">
                <h1>
                    {{ 'home.title' | trans }}
                </h1>

                <p class="text--primary text--big">
                    {{ 'home.intro' | trans }}
                </p>
            </div>

            <div style="flex: 1; text-align: center;">
                <img
                    alt=""
                    src="{{ asset('calendar.png') }}"
                    fetchpriority="high"
                    decoding="async"
                    width="403"
                    height="261"
                    style="max-width: 100%; height: auto;"
                >
            </div>
        </div>

        <div class="cols cols--center cols--gap home-stats" style="display: flex; justify-content: center; gap: 45px; margin-top: 30px; margin-bottom: 30px; flex-wrap: wrap;">
            <div class="stat-item" style="text-align: center; min-width: 120px;">
                <span class="stat-number" style="display: block; font-size: 2.2em; font-weight: bold; color: var(--color-primary, #2d6b9e); line-height: 1.2;">{{ pollsCount }}</span>
                <span class="stat-label text--secondary" style="font-size: 0.95em;">{{ 'home.stats.polls' | trans({ count: pollsCount }) }}</span>
            </div>
            <div class="stat-item" style="text-align: center; min-width: 120px;">
                <span class="stat-number" style="display: block; font-size: 2.2em; font-weight: bold; color: var(--color-primary, #2d6b9e); line-height: 1.2;">{{ votesCount }}</span>
                <span class="stat-label text--secondary" style="font-size: 0.95em;">{{ 'home.stats.votes' | trans({ count: votesCount }) }}</span>
            </div>
            <div class="stat-item" style="text-align: center; min-width: 120px;">
                <span class="stat-number" style="display: block; font-size: 2.2em; font-weight: bold; color: var(--color-primary, #2d6b9e); line-height: 1.2;">{{ votersCount }}</span>
                <span class="stat-label text--secondary" style="font-size: 0.95em;">{{ 'home.stats.participants' | trans({ count: votersCount }) }}</span>
            </div>
            <div class="stat-item" style="text-align: center; min-width: 120px;">
                <span class="stat-number" style="display: block; font-size: 2.2em; font-weight: bold; color: var(--color-primary, #2d6b9e); line-height: 1.2;">{{ commentsCount }}</span>
                <span class="stat-label text--secondary" style="font-size: 0.95em;">{{ 'home.stats.comments' | trans({ count: commentsCount }) }}</span>
            </div>
        </div>

        <p class="cols cols--center cols--gap" style="display: flex; justify-content: center; gap: 10px; flex-wrap: wrap;">
            <a class="button button--primary" href="{{ path('choose poll type') }}">
                {{ 'home.create_poll' | trans }}
            </a>

            <a class="button" href="{{ path('public polls') }}">
                {{ 'home.public_polls' | trans }}
            </a>

            <a class="button" href="{{ path('my') }}">
                {{ 'home.my_polls_and_votes' | trans }}
            </a>
        </p>

        <p class="text--secondary" style="text-align: center; font-size: 0.9em;">
            {{ 'home.credits' | trans | raw }}
        </p>

    </div>
{% endblock %}
