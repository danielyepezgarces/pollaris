{% extends 'base.html.twig' %}

{% block robots_head_tags %}{% endblock %}

{% block main_class %}layout__body--centered{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ esbuild_asset('home/application.css') }}" data-turbo-track="reload">
{% endblock %}

{% block body %}
    <div class="flow flow--larger" style="max-width: 900px; width: 100%; text-align: center;">

        {% for message in app.flashes('success') %}
            {% if message == 'poll.deleted' %}
                {{ include('notifications/_success.html.twig', { message: 'home.show.poll.deleted' | trans }) }}
            {% endif %}
        {% endfor %}

        <div class="cols cols--gap-large" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px;">
            <div class="col--extend flow flow--large" style="flex: 1;">
                <h1>
                    {{ 'home.title' | trans }}
                </h1>

                <p class="text--primary text--big">
                    {{ 'home.intro' | trans }}
                </p>
            </div>

            <div style="flex: 1; text-align: center;">
                <img
                    alt=""
                    src="{{ asset('calendar.png') }}"
                    fetchpriority="high"
                    decoding="async"
                    width="403"
                    height="261"
                    style="max-width: 100%; height: auto;"
                >
            </div>
        </div>

        <p class="cols cols--center cols--gap" style="display: flex; justify-content: center; gap: 10px; flex-wrap: wrap;">
            <a class="button button--primary" href="{{ path('choose poll type') }}">
                {{ 'home.create_poll' | trans }}
            </a>

            <a class="button" href="{{ path('public polls') }}">
                {{ 'home.public_polls' | trans }}
            </a>

            <a class="button" href="{{ path('my') }}">
                {{ 'home.my_polls_and_votes' | trans }}
            </a>
        </p>

        <p class="text--secondary" style="text-align: center; font-size: 0.9em;">
            {{ 'home.credits' | trans | raw }}
        </p>

    </div>
{% endblock %}
