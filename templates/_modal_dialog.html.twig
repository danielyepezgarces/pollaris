<div
    id="modal"
    class="modal"
    role="dialog"
    data-controller="modal"
    data-action="click->modal#closeOnMask"
    aria-modal="true"
    aria-hidden="true"
    tabindex="-1"
>
    <section
        class="modal__box"
        data-modal-target="box"
        role="document"
    >
        <header class="modal__header">
            <button
                type="button"
                class="button--ghost button--small"
                data-action="modal#close"
            >
                {{ 'layout.modal.close' | trans }}
                {{ icon('xmark') }}
            </button>
        </header>

        <div data-modal-target="body" class="modal__body">
            <turbo-frame data-modal-target="content">
                <div class="bear-with-me"></div>
            </turbo-frame>
        </div>
    </section>
</div>
