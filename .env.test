# This file defines a list of environment variables used to configure the application.
#
# They are used in the test environment.
#
# To configure the application in production, copy the file env.sample as .env.local instead.

####################################
# Configuration of the application #
####################################
APP_SECRET="$ecretf0rt3st"
APP_BASE_URL="http://localhost:8000"
APP_REQUIRE_EMAILS=true
WIKIMEDIA_OAUTH_ENABLED=false
WIKIMEDIA_OAUTH_BASE_URL="https://meta.wikimedia.org/w/rest.php/oauth"
WIKIMEDIA_OAUTH_CLIENT_ID=""
WIKIMEDIA_OAUTH_CLIENT_SECRET=""
WIKIMEDIA_OAUTH_USER_AGENT=""

#################################
# Poll expiration configuration #
#################################
POLL_EXPIRES_COMPLETED="+6 months"
POLL_EXPIRES_INCOMPLETE="+2 months"

#################################
# Configuration of the database #
#################################
#DATABASE_URL="postgresql://postgres:postgres@database:5432/pollaris?serverVersion=15&charset=utf8"
DATABASE_URL="mysql://root:root@database:3306/pollaris?serverVersion=mariadb-10.11.2&charset=utf8mb4"

#####################################
# Configuration of the async system #
#####################################
MESSENGER_TRANSPORT_DSN="sync://"

###########################################
# Configuration specific to Symfony tests #
###########################################
KERNEL_CLASS='App\Kernel'

SYMFONY_DEPRECATIONS_HELPER=999999
