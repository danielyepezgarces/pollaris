# This file defines a list of environment variables used to configure the application.
# Please copy this file as .env.local to configure the application in production.

####################################
# Configuration of the application #
####################################
# Define the environment of the application. It can be: prod, dev, test
# Don't change this value unless you know what you do.
APP_ENV="prod"

# A secret used to generate security tokens, **it must be changed!**
APP_SECRET="change-me"

# The base URL that serves your application. It is used to generate URLs in
# non-HTTP contexts (i.e. from the command line).
APP_BASE_URL="https://example.org"

# If Pollaris runs behind a reverse proxy (Nginx, Traefik, Cloudflare, etc.),
# configure trusted proxies/hosts so Symfony can detect HTTPS correctly.
# TRUSTED_PROXIES="127.0.0.1,REMOTE_ADDR"
# TRUSTED_HOSTS="^example\.org$|^www\.example\.org$"

# Set to customise the name of the application ("Pollaris" by default).
# APP_NAME="Pollaris"

# Uncomment to force the polls' authors to enter an email.
# APP_REQUIRE_EMAILS=true

# Wikimedia OAuth 1.0a login. Register your app on Wikimedia and fill these
# values to allow login with Wikipedia / Wikimedia accounts.
# WIKIMEDIA_OAUTH_ENABLED=true
# WIKIMEDIA_OAUTH_BASE_URL="https://meta.wikimedia.org/w/rest.php/oauth"
# WIKIMEDIA_OAUTH_CLIENT_ID=""
# WIKIMEDIA_OAUTH_CLIENT_SECRET=""
# WIKIMEDIA_OAUTH_USER_AGENT="Pollaris/1.1.3 (https://pollaris.example.org; admin@example.org)"

####################################
# Poll expiration configuration    #
####################################
# Uncomment to define how long polls are kept in database after they are closed.
# Values must use valid PHP DateTime relative date format.
# Examples: "7 days", "2 weeks", "6 months"
# Empty strings disable polls expiration.

# Expiration delay for completed polls (creation fully finalized)
# POLL_EXPIRES_COMPLETED="6 months"

# Expiration delay for non-completed polls (creation not finalized)
# POLL_EXPIRES_INCOMPLETE="1 month"

#################################
# Configuration of the database #
#################################
# URL to connect to the database.
# Please adapt the credentials and the serverVersion.
DATABASE_URL="postgresql://user:password@localhost:5432/pollaris_production?serverVersion=15&charset=utf8"

########################################
# Configuration of the SMTP mailserver #
########################################
# Configure your mail server. It is used to send email notifications to the admins and participants.
# Uncomment the MAILER_* lines and set them to your needs.
# More documentation at https://symfony.com/doc/current/mailer.html (“Transport Setup”).
# MAILER_DSN="smtp://user:pass@mail.example.com:465"
# MAILER_FROM="noreply@example.com"
# MAILER_FROM_NAME="Pollaris admin"

#####################################
# Configuration of the async system #
#####################################
# Configure the Symfony Messenger transport.
# You should not change this value unless you know what you're doing.
# More documentation at https://symfony.com/doc/current/messenger.html#transport-configuration
MESSENGER_TRANSPORT_DSN="doctrine://default?auto_setup=0"
